{
  "name": "podofo",
  "description": "PoDoFo is a library to work with the PDF file format",
  "homepage": "https://github.com/podofo/podofo",
  "license": "LGPL-2.0-or-later",
  "dependencies": [
    "zlib",
    "utf8proc",
    "utfcpp",
    "date",
    "fast-float",
    "fmt",
    "freetype",
    "fontconfig",
    "libjpeg-turbo",
    "libpng",
    {
      "name": "tiff",
      "default-features": false
    },
    {
      "name": "libxml2",
      "default-features": false
    },
    "openssl",
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    }
  ]
}